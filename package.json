{
  "name": "qnlabs",
  "version": "0.3.4",
  "description": "GitHub-based file distribution CLI — pull any file from any repo directly into your project",
  "bin": {
    "qnlabs": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "tsup",
    "build:watch": "tsup --watch",
    "prepublishOnly": "tsup"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@octokit/rest": "^21.0.0",
    "commander": "^12.0.0",
